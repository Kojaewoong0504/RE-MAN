{
  "name": "re-man",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3001",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "smoke:feedback:gemini": "python3 scripts/smoke-feedback-gemini.py",
    "smoke:feedback:browser": "node scripts/smoke-feedback-browser-gemini.mjs",
    "check:architecture": "python3 harness/architecture/run.py",
    "check:repo": "python3 harness/repository/run.py",
    "check:app": "python3 harness/application/run.py",
    "check:content": "python3 harness/application/content_rules.py",
    "check:gc": "python3 harness/gc/run.py",
    "check": "python3 harness/repository/run.py && python3 harness/application/run.py && python3 harness/application/content_rules.py && python3 harness/architecture/run.py && python3 harness/gc/run.py && tsc --noEmit && next lint && next build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "jose": "^6.2.2",
    "next": "14.2.30",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@types/node": "22.15.3",
    "@types/react": "18.3.20",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.21",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.30",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vitest": "^4.1.3"
  }
}
