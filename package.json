{
  "name": "re-man",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "NODE_OPTIONS='--require ./scripts/enable-next-wasm.cjs' next dev --hostname 127.0.0.1 --port 3001",
    "build": "rm -rf .next && NODE_OPTIONS='--require ./scripts/enable-next-wasm.cjs' python3 scripts/with-next-artifact-lock.py build -- next build",
    "start": "NODE_OPTIONS='--require ./scripts/enable-next-wasm.cjs' next start --hostname 127.0.0.1 --port 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:unit": "node scripts/run-vitest-local.mjs tests/unit",
    "test:integration": "node scripts/run-vitest-local.mjs tests/integration",
    "test:e2e": "python3 scripts/with-next-artifact-lock.py e2e -- playwright test",
    "visual:app": "python3 scripts/with-next-artifact-lock.py visual-app -- node scripts/visual-app-smoke.mjs",
    "visual:deep-dive": "python3 scripts/with-next-artifact-lock.py visual-deep-dive -- node scripts/visual-deep-dive-smoke.mjs",
    "smoke:feedback:gemini": "python3 scripts/smoke-feedback-gemini.py",
    "smoke:feedback:browser": "node scripts/smoke-feedback-browser-gemini.mjs",
    "smoke:closet:gemini": "python3 scripts/smoke-closet-gemini.py",
    "smoke:try-on:vertex": "python3 scripts/smoke-try-on-vertex.py",
    "smoke:production:mvp": "node scripts/smoke-production-mvp.mjs",
    "perf:app-shell": "node scripts/perf-app-shell.mjs",
    "check:architecture": "python3 harness/architecture/run.py",
    "check:repo": "python3 harness/repository/run.py",
    "check:app": "python3 harness/application/run.py",
    "check:content": "python3 harness/application/content_rules.py",
    "check:gc": "python3 harness/gc/run.py",
    "check:mvp": "python3 harness/mvp/run.py",
    "check:deploy": "node scripts/check-deploy-readiness.mjs",
    "check:deploy:strict": "node scripts/check-deploy-readiness.mjs --strict",
    "check:deploy:vercel": "node scripts/pull-vercel-production-env.mjs && node scripts/check-deploy-readiness.mjs --strict",
    "check": "python3 harness/repository/run.py && python3 harness/application/run.py && python3 harness/application/content_rules.py && python3 harness/architecture/run.py && python3 harness/gc/run.py && npm run check:mvp && tsc --noEmit && next lint && next build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "heic2any": "^0.0.4",
    "jose": "^6.2.2",
    "next": "14.2.30",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "^14.2.30",
    "@playwright/test": "1.54.2",
    "@types/node": "22.15.3",
    "@types/react": "18.3.20",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.21",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.30",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vitest": "^4.1.3"
  }
}
